# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=drupal_db
DB_USER=drupal_user
DB_PASSWORD=your_database_password
DB_DRIVER=mysql
DB_PREFIX=

# Drupal Settings
DRUPAL_HASH_SALT=your-random-hash-salt-here

# Site Configuration
SITE_NAME=Video Platform
SITE_MAIL=admin@example.com
ACCOUNT_MAIL=admin@example.com

# Trusted Host Patterns (comma-separated)
TRUSTED_HOST_PATTERNS=^localhost$,^example\.com$

# File Paths
PUBLIC_FILES_PATH=sites/default/files
PRIVATE_FILES_PATH=../private
TEMP_PATH=/tmp

# Performance
CACHE_ENABLED=1
AGGREGATION_ENABLED=1

# Development (set to 0 in production)
DEBUG=0
DISABLE_CACHE=0
